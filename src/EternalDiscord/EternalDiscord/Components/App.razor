@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@BaseHref" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["EternalDiscord.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
</head>

<body>
    <Routes @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <style>
        /* Reserve room for the EternalSocial pinned footer; --es-footer-h is
           published by the gateway's injected footer and absent when the app
           is reached directly, so this collapses to zero. The shell owns the
           whole reservation (body padding would add a dead scroll strip). */
        .discord-shell { height: calc(100dvh - var(--es-footer-h, 0rem)); }
    </style>
    @* Razor strips literal HTML comments from component output, so emit the
       gateway footer marker as markup. *@
    @((MarkupString)"<!--ETERNALSOCIAL-FOOTER-->")
</body>

</html>

@code {
    // Matches Proxy:PathBase so the document base agrees with UsePathBase ("" => "/").
    private string BaseHref => (Configuration["Proxy:PathBase"] ?? string.Empty).TrimEnd('/') + "/";
}
